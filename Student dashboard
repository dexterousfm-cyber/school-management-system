<!DOCTYPE html>
<html>
<head>
    <title>Student Dashboard</title>
</head>
<body>

<h1>My Report Card</h1>

<div id="report"></div>

<script>
let loggedIn = JSON.parse(localStorage.getItem("loggedInUser"));

if(!loggedIn || loggedIn.role !== "student"){
    alert("Access denied");
    window.location.href="index.html";
}

function getGrade(score){
    score = Number(score);
    if(score >= 70) return "A";
    if(score >= 60) return "B";
    if(score >= 50) return "C";
    if(score >= 45) return "D";
    if(score >= 40) return "E";
    return "F";
}

let output = `
<h3>${loggedIn.name}</h3>
<p>Class: ${loggedIn.class}</p>
<hr>
`;

if(!loggedIn.results){
    output += "<p>No results yet</p>";
}else{
    for(let term in loggedIn.results){
        output += "<h3>" + term + "</h3>";

        let total = 0;
        let count = 0;

        for(let sub in loggedIn.results[term]){
            let score = loggedIn.results[term][sub];
            let grade = getGrade(score);

            total += Number(score);
            count++;

            output += `<p>${sub}: ${score} (${grade})</p>`;
        }

        if(count > 0){
            let avg = (total / count).toFixed(2);
            output += `<p><b>Average: ${avg}</b></p>`;
        }
    }
}

document.getElementById("report").innerHTML = output;
</script>

</body>
</html>
