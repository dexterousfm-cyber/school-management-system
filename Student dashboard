<!DOCTYPE html>
<html>
<head>
    <title>Student Dashboard - ADUE Portal</title>
    <style>
        body{ font-family:Arial; max-width:600px; margin:30px auto; padding:20px; }
        table{ width:100%; border-collapse: collapse; margin-top:20px; }
        th, td{ border:1px solid #ccc; padding:8px; text-align:left; }
    </style>
</head>
<body>

<h2>Student Dashboard</h2>
<button onclick="logout()">Logout</button>

<p id="studentInfo"></p>

<h3>Results</h3>
<table id="resultsTable">
<tr><th>Subject</th><th>Score</th><th>Term</th></tr>
</table>

<script>
let users=JSON.parse(localStorage.getItem("users"))||[];
let loggedUser=JSON.parse(localStorage.getItem("loggedInUser"));
if(!loggedUser||loggedUser.role!=="student"){ alert("Access denied"); window.location.href="index.html"; }

document.getElementById("studentInfo").innerText=`Name: ${loggedUser.name} | Class: ${loggedUser.class||"-"}`;

function loadResults(){
    let table=document.getElementById("resultsTable");
    table.innerHTML="<tr><th>Subject</th><th>Score</th><th>Term</th></tr>";
    if(loggedUser.results){
        loggedUser.results.forEach(r=>{ table.innerHTML+=`<tr><td>${r.subject}</td><td>${r.score}</td><td>${r.term}</td></tr>`; });
    }
}
function logout(){ localStorage.removeItem("loggedInUser"); window.location.href="index.html"; }

loadResults();
</script>

</body>
</html>
